TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_REGISTRY_FILE=./board-registry.json
TRELLO_ALLOWED_BOARD_IDS=actual_main_board_id,actual_staging_board_id
# Optional; used only by promote_staging_task to prevent duplicate destination cards on retries.
TRELLO_PROMOTION_STORE_PATH=./.trello-promotion-idempotency.json
# Optional; defaults to https://api.trello.com/1.
TRELLO_API_BASE_URL=https://api.trello.com/1
